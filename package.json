{
  "name": "sales-data-aggregation-pipeline",
  "version": "1.0.0",
  "description": "A TypeScript prototype for aggregating sales events from multiple source types (API, database, and file) into a normalized structure.",
  "main": "index.js",
  "scripts": {
    "start": "node node_modules/@tailwindcss/cli/dist/index.mjs -i ./ui/tailwind.css -o ./ui/styles.css && node node_modules/ts-node/dist/bin.js server.ts",
    "pipline": "npm run pipeline",
    "pipeline": "node node_modules/ts-node/dist/bin.js index.ts",
    "build:css": "node node_modules/@tailwindcss/cli/dist/index.mjs -i ./ui/tailwind.css -o ./ui/styles.css",
    "tailwind:watch": "node node_modules/@tailwindcss/cli/dist/index.mjs -i ./ui/tailwind.css -o ./ui/styles.css --watch",
    "dashboard": "npm start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmniaEladawy/Sales-Data-Aggregation-Pipeline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/OmniaEladawy/Sales-Data-Aggregation-Pipeline/issues"
  },
  "homepage": "https://github.com/OmniaEladawy/Sales-Data-Aggregation-Pipeline#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.6.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
